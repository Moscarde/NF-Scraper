# =============================================================
# .env.example — Copie para .env e preencha os valores
# =============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=seu_token_aqui

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nfe
POSTGRES_USER=nfe_user
POSTGRES_PASSWORD=senha_segura_aqui

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Paths (dentro dos containers) ---
IMAGES_DIR=/app/received_images
SCRAPED_HTML_DIR=/app/scraped_html

# --- Logging ---
LOG_LEVEL=INFO
